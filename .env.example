# ===========================================
# AI Training Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# Application Configuration
# ===========================================
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ===========================================
# Database Configuration
# ===========================================
# Local development
DATABASE_URL=mysql+aiomysql://ai_training:ai_training_pass@localhost:3306/ai_training

# Docker Compose development
# DATABASE_URL=mysql+aiomysql://ai_training:ai_training_pass@mysql:3306/ai_training

# MySQL service configuration (for Docker Compose)
MYSQL_ROOT_PASSWORD=devpassword
MYSQL_DATABASE=ai_training
MYSQL_USER=ai_training
MYSQL_PASSWORD=ai_training_pass

# ===========================================
# AWS Configuration
# ===========================================
AWS_REGION=us-east-1

# Option 1: Use AWS CLI profile (recommended for development)
AWS_PROFILE=default

# Option 2: Use access keys directly (not recommended, use IAM roles in production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ===========================================
# HyperPod Configuration
# ===========================================
HYPERPOD_CLUSTER_ARN=arn:aws:sagemaker:us-east-1:123456789012:cluster/your-cluster-name
HYPERPOD_CLUSTER_NAME=your-cluster-name

# ===========================================
# S3 Storage Configuration
# ===========================================
S3_DATASETS_BUCKET=ai-training-datasets-dev
S3_MODELS_BUCKET=ai-training-models-dev
S3_CHECKPOINTS_BUCKET=ai-training-checkpoints-dev

# ===========================================
# FSx for Lustre Configuration
# ===========================================
FSX_LUSTRE_MOUNT_PATH=/fsx
FSX_LUSTRE_FILE_SYSTEM_ID=fs-0123456789abcdef0

# ===========================================
# Frontend Configuration
# ===========================================
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ===========================================
# Security Configuration
# ===========================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# Observability Configuration
# ===========================================
# CloudWatch Logs
CLOUDWATCH_LOG_GROUP=/ai-training-platform/dev
CLOUDWATCH_LOG_RETENTION_DAYS=30

# ===========================================
# Developer IAM Permissions Required
# ===========================================
# The following IAM permissions are required for local development:
# - sagemaker:* (HyperPod operations)
# - eks:DescribeCluster, eks:ListClusters (EKS access)
# - s3:GetObject, s3:PutObject, s3:ListBucket (S3 storage)
# - logs:CreateLogGroup, logs:CreateLogStream, logs:PutLogEvents (CloudWatch)
# - fsx:DescribeFileSystems (FSx for Lustre)
#
# Configure kubectl for EKS:
# aws eks update-kubeconfig --name <cluster-name> --region <region>
