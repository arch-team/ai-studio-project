# AWS Integration Test Configuration
# 用于 T036/T036a HyperPod 和 Gang Scheduling 集成测试

# AWS 配置
AWS_REGION=us-east-1
AWS_PROFILE=default

# HyperPod 测试配置
HYPERPOD_TEST_CLUSTER_NAME=ai-platform-dev-hyperpod

# 写入测试控制 (默认禁用以避免费用)
# 设置为 true 启用创建训练任务的测试
HYPERPOD_ENABLE_WRITE_TESTS=false

# S3 测试配置 (如需要)
# S3_TEST_BUCKET=ai-training-platform-integration-test
# S3_TEST_PREFIX=integration-tests/
