# 应用配置
APP_NAME="AI Training Platform"
APP_VERSION="0.1.0"
ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# API配置
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# 数据库配置
DATABASE_URL=postgresql+asyncpg://ai_platform:dev_password@localhost:5432/ai_training_platform
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# JWT认证配置
JWT_SECRET_KEY=your-secret-key-change-in-production-use-strong-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# TLS/HTTPS配置
TLS_ENABLED=false
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem
TLS_MIN_VERSION=TLSv1.2

# AWS配置
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Kubernetes配置
K8S_NAMESPACE=ai-training-platform
# K8S_CONFIG_PATH=/path/to/kubeconfig
K8S_IN_CLUSTER=false

# HyperPod配置
# HYPERPOD_CLUSTER_NAME=my-hyperpod-cluster
HYPERPOD_TRAINING_OPERATOR_NAMESPACE=hyperpod-training-operator

# 存储配置
# S3_BUCKET=my-training-data-bucket
# FSX_FILESYSTEM_ID=fs-0123456789abcdef
FSX_MOUNT_PATH=/fsx
# EFS_FILESYSTEM_ID=fs-0123456789abcdef
EFS_MOUNT_PATH=/efs

# 监控配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
# GRAFANA_URL=http://localhost:3001

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
