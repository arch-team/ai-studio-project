# AWS Integration Test Configuration
# Copy this file to .env.aws-integration and fill in your values
# DO NOT commit .env.aws-integration to version control!

# AWS Authentication
# Option 1: Use AWS CLI Profile (Recommended for local development)
AWS_PROFILE=ai-platform-integration-test

# Option 2: Use explicit credentials (for CI/CD only)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# AWS Region
AWS_REGION=us-east-1

# S3 Test Configuration
S3_TEST_BUCKET=ai-training-platform-integration-test
S3_TEST_PREFIX=integration-tests/
# Optional: KMS Key for encryption tests
# S3_TEST_KMS_KEY_ID=alias/ai-platform-test-key

# HyperPod Test Configuration (Read-only by default)
HYPERPOD_TEST_CLUSTER_NAME=your-test-cluster

# Enable destructive HyperPod tests (WARNING: incurs charges!)
# HYPERPOD_ENABLE_WRITE_TESTS=true

# Required for HyperPod write tests (if enabled)
# TEST_SECURITY_GROUP=sg-xxxxxxxxx
# TEST_SUBNET=subnet-xxxxxxxxx
