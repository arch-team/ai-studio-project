@startuml HyperPod Network Traffic Flow
!theme aws-orange
title SageMaker HyperPod Cluster - Network Traffic Sequence Diagram\nCluster: ai-platform-dev-hyperpod (ndownj7gq0f5)

skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam BoxPadding 10
skinparam ParticipantPadding 20

actor User as user #LightBlue
participant "Internet Gateway" as igw #Purple
participant "NAT Gateway\nnat-0a2f700bf148654c4" as nat #Purple
participant "VPC Endpoint (S3)\nvpce-0a918bfadc4ddf2dd" as vpce #Purple
box "Private Subnet (us-east-1a)\n10.0.64.0/19" #LightCyan
    participant "Security Group\nsg-0181ce722a74d3f86" as sg #Red
    participant "EKS Control Plane\nai-platform-dev-eks" as eks #Orange
    participant "Controller Node\nml.m5.xlarge" as node #Orange
end box
participant "IAM Service" as iam #Red
participant "S3 Bucket\nsagemaker-ai-platform-dev-lifecycle" as s3 #Green
participant "SageMaker API" as sagemaker #Orange
participant "CloudWatch" as cloudwatch #Pink

== Cluster Initialization ==

user -> sagemaker: CreateCluster API Call
activate sagemaker
sagemaker -> iam: AssumeRole\n(ai-platform-dev-hyperpod-execution-role)
activate iam
iam --> sagemaker: Temporary Credentials
deactivate iam

sagemaker -> eks: Create/Configure EKS Cluster
activate eks
eks --> sagemaker: EKS Cluster ARN
deactivate eks

sagemaker -> node: Provision ml.m5.xlarge Instance
activate node
node --> sagemaker: Instance Ready
sagemaker --> user: Cluster Status: Creating
deactivate sagemaker

== Node Lifecycle Configuration ==

node -> sg: Egress Rule Check
activate sg
sg --> node: Allow Outbound Traffic
deactivate sg

node -> vpce: Request Lifecycle Scripts\n(via VPC Endpoint)
activate vpce
vpce -> s3: GetObject\n(on_create.sh)
activate s3
s3 --> vpce: Lifecycle Script
deactivate s3
vpce --> node: Script Downloaded
deactivate vpce

node -> node: Execute on_create.sh
activate node
note right: Bootstrap node\nInstall dependencies\nConfigure environment
deactivate node

node -> cloudwatch: Send Initialization Logs
activate cloudwatch
cloudwatch --> node: Logs Acknowledged
deactivate cloudwatch

== Training Job Execution ==

user -> sagemaker: Submit Training Job
activate sagemaker
sagemaker -> eks: Schedule Pod on Controller Node
activate eks
eks -> node: Deploy Training Container
activate node

node -> iam: Validate IAM Permissions
activate iam
iam --> node: Permissions Granted
deactivate iam

node -> sg: Check Security Group Rules
activate sg
sg --> node: Traffic Allowed
deactivate sg

node -> vpce: Access Training Data from S3
activate vpce
vpce -> s3: GetObject (Training Dataset)
activate s3
s3 --> vpce: Training Data
deactivate s3
vpce --> node: Data Retrieved
deactivate vpce

node -> node: Execute Training
activate node
note right: Model training\nGPU/CPU computation\nCheckpoint saving
deactivate node

node -> vpce: Save Model Artifacts to S3
activate vpce
vpce -> s3: PutObject (Model Files)
activate s3
s3 --> vpce: Upload Complete
deactivate s3
vpce --> node: Artifacts Saved
deactivate vpce

node -> cloudwatch: Send Training Metrics & Logs
activate cloudwatch
cloudwatch --> node: Metrics Recorded
deactivate cloudwatch

node --> eks: Training Complete
deactivate node
eks --> sagemaker: Job Status Update
deactivate eks
sagemaker --> user: Training Job Completed
deactivate sagemaker

== External Package Installation ==

node -> sg: Outbound Request (pip/conda)
activate sg
sg --> node: Allow Outbound
deactivate sg

node -> nat: Request to PyPI/Conda Forge
activate nat
nat -> igw: Forward to Internet
activate igw
igw -> igw: Route to PyPI
igw --> nat: Package Data
deactivate igw
nat --> node: Package Downloaded
deactivate nat

== Node Health Monitoring ==

loop Every 30 seconds
    node -> cloudwatch: Send Health Metrics\n(CPU, Memory, Disk, Network)
    activate cloudwatch
    cloudwatch --> node: Acknowledged
    deactivate cloudwatch
end

sagemaker -> node: Health Check
activate node
node --> sagemaker: Status: Healthy
deactivate node

== Node Failure & Auto Recovery ==

node -> node: Node Failure Detected
activate node #Red
node -[#Red]> cloudwatch: Critical Error Logs
deactivate node

sagemaker -> sagemaker: Detect Node Failure
activate sagemaker #Red
note right: Automatic Node Recovery\nEnabled
sagemaker -> node: Terminate Failed Instance
sagemaker -> node: Launch Replacement Instance
activate node
node -> vpce: Download Lifecycle Scripts
activate vpce
vpce -> s3: GetObject (on_create.sh)
activate s3
s3 --> vpce: Script
deactivate s3
vpce --> node: Script Retrieved
deactivate vpce

node -> node: Re-execute Bootstrap
node -> eks: Register with EKS
activate eks
eks --> node: Node Registered
deactivate eks

node --> sagemaker: Node Status: InService
deactivate node
sagemaker --> user: Node Recovered
deactivate sagemaker

== Cluster Update (Software Upgrade) ==

user -> sagemaker: UpdateClusterSoftware API
activate sagemaker
sagemaker -> node: Drain Workloads
activate node
node -> eks: Cordon & Drain Node
activate eks
eks --> node: Workloads Migrated
deactivate eks

sagemaker -> node: Update AMI/Software
node -> node: Apply Updates
node -> node: Reboot

node -> eks: Re-register Node
activate eks
eks --> node: Node Ready
deactivate eks

node --> sagemaker: Update Complete
deactivate node
sagemaker --> user: Cluster Updated
deactivate sagemaker

== Cluster Monitoring & Observability ==

loop Continuous
    node -> cloudwatch: Metrics & Logs
    activate cloudwatch
    cloudwatch --> node: Acknowledged
    deactivate cloudwatch
    
    user -> cloudwatch: Query Metrics/Logs
    activate cloudwatch
    cloudwatch --> user: Dashboard Data
    deactivate cloudwatch
end

== Cluster Deletion ==

user -> sagemaker: DeleteCluster API
activate sagemaker
sagemaker -> eks: Delete EKS Resources
activate eks
eks -> node: Terminate Instances
activate node
node -> cloudwatch: Final Logs
activate cloudwatch
cloudwatch --> node: Acknowledged
deactivate cloudwatch
node --> eks: Instance Terminated
deactivate node
eks --> sagemaker: EKS Resources Deleted
deactivate eks

sagemaker -> iam: Cleanup IAM Session
activate iam
iam --> sagemaker: Session Revoked
deactivate iam

sagemaker --> user: Cluster Deleted
deactivate sagemaker

@enduml
