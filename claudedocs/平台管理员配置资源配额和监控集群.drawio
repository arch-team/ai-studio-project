        <mxCell id="msg30" value="30. 返回使用情况&#xa;市场部: 40/50 GPU (80%)&#xa;研发部: 85/100 GPU (85%)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#009900;dashed=1;" edge="1" parent="1">
