{
  "Outputs": {
    "AlbArn": {
      "Description": "ALB ARN for reference",
      "Export": {
        "Name": "ai-platform-dev-alb-arn"
      },
      "Value": {
        "Ref": "ApplicationLoadBalancer<TOKEN>"
      }
    },
    "AlbDnsName": {
      "Description": "ALB DNS name for frontend access",
      "Export": {
        "Name": "ai-platform-dev-alb-dns"
      },
      "Value": {
        "Fn::GetAtt": [
          "ApplicationLoadBalancer<TOKEN>",
          "DNSName"
        ]
      }
    },
    "BackendTargetGroupArn": {
      "Description": "Backend API Target Group ARN",
      "Export": {
        "Name": "ai-platform-dev-backend-tg-arn"
      },
      "Value": {
        "Ref": "BackendTargetGroup<TOKEN>"
      }
    },
    "FrontendTargetGroupArn": {
      "Description": "Frontend Target Group ARN",
      "Export": {
        "Name": "ai-platform-dev-frontend-tg-arn"
      },
      "Value": {
        "Ref": "FrontendTargetGroup<TOKEN>"
      }
    },
    "HttpListenerArn": {
      "Description": "HTTP Listener ARN (dev environment - no TLS)",
      "Export": {
        "Name": "ai-platform-dev-http-listener-arn"
      },
      "Value": {
        "Ref": "ApplicationLoadBalancerHttpListener<TOKEN>"
      }
    },
    "HttpOnlyWarning": {
      "Description": "Security warning for HTTP-only configuration",
      "Value": "WARNING: This ALB uses HTTP only (no TLS). Not suitable for production!"
    },
    "SecurityGroupId": {
      "Description": "ALB Security Group ID",
      "Export": {
        "Name": "ai-platform-dev-alb-sg-id"
      },
      "Value": {
        "Fn::GetAtt": [
          "AlbSecurityGroup<TOKEN>",
          "GroupId"
        ]
      }
    }
  },
  "Parameters": {
    "BootstrapVersion": {
      "Default": "/cdk-bootstrap/hnb659fds/version",
      "Description": "Version of the CDK Bootstrap resources in this environment, automatically retrieved from SSM Parameter Store. [cdk:skip]",
      "Type": "AWS::SSM::Parameter::Value<String>"
    }
  },
  "Resources": {
    "AlbSecurityGroup<TOKEN>": {
      "Properties": {
        "GroupDescription": "Security group for Application Load Balancer",
        "SecurityGroupEgress": [
          {
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow all outbound traffic by default",
            "IpProtocol": "-1"
          }
        ],
        "SecurityGroupIngress": [
          {
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow HTTPS from internet",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          },
          {
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow HTTP from internet (redirect to HTTPS)",
            "FromPort": 80,
            "IpProtocol": "tcp",
            "ToPort": 80
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "ai-platform-dev-alb-sg"
          }
        ],
        "VpcId": {
          "Fn::ImportValue": "SnapshotVpc:ExportsOutputRefVpc<TOKEN>"
        }
      },
      "Type": "AWS::EC2::SecurityGroup"
    },
    "ApplicationLoadBalancer<TOKEN>": {
      "Properties": {
        "LoadBalancerAttributes": [
          {
            "Key": "deletion_protection.enabled",
            "Value": "false"
          },
          {
            "Key": "routing.http2.enabled",
            "Value": "true"
          },
          {
            "Key": "idle_timeout.timeout_seconds",
            "Value": "60"
          },
          {
            "Key": "routing.http.drop_invalid_header_fields.enabled",
            "Value": "true"
          }
        ],
        "Name": "ai-platform-dev-alb",
        "Scheme": "internet-facing",
        "SecurityGroups": [
          {
            "Fn::GetAtt": [
              "AlbSecurityGroup<TOKEN>",
              "GroupId"
            ]
          }
        ],
        "Subnets": [
          {
            "Fn::ImportValue": "SnapshotVpc:ExportsOutputRefVpcPublicSubnet1Subnet<TOKEN>"
          },
          {
            "Fn::ImportValue": "SnapshotVpc:ExportsOutputRefVpcPublicSubnet2Subnet<TOKEN>"
          },
          {
            "Fn::ImportValue": "SnapshotVpc:ExportsOutputRefVpcPublicSubnet3Subnet<TOKEN>"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "ai-platform-dev-alb"
          }
        ],
        "Type": "application"
      },
      "Type": "AWS::ElasticLoadBalancingV2::LoadBalancer"
    },
    "ApplicationLoadBalancerHttpListener<TOKEN>": {
      "Properties": {
        "DefaultActions": [
          {
            "FixedResponseConfig": {
              "ContentType": "text/plain",
              "MessageBody": "Not Found",
              "StatusCode": "404"
            },
            "Type": "fixed-response"
          }
        ],
        "LoadBalancerArn": {
          "Ref": "ApplicationLoadBalancer<TOKEN>"
        },
        "Port": 80,
        "Protocol": "HTTP"
      },
      "Type": "AWS::ElasticLoadBalancingV2::Listener"
    },
    "ApplicationLoadBalancerHttpListenerBackendApiRuleRule<TOKEN>": {
      "Properties": {
        "Actions": [
          {
            "TargetGroupArn": {
              "Ref": "BackendTargetGroup<TOKEN>"
            },
            "Type": "forward"
          }
        ],
        "Conditions": [
          {
            "Field": "path-pattern",
            "PathPatternConfig": {
              "Values": [
                "/api/*",
                "/health"
              ]
            }
          }
        ],
        "ListenerArn": {
          "Ref": "ApplicationLoadBalancerHttpListener<TOKEN>"
        },
        "Priority": 10
      },
      "Type": "AWS::ElasticLoadBalancingV2::ListenerRule"
    },
    "ApplicationLoadBalancerHttpListenerFrontendRuleRule<TOKEN>": {
      "Properties": {
        "Actions": [
          {
            "TargetGroupArn": {
              "Ref": "FrontendTargetGroup<TOKEN>"
            },
            "Type": "forward"
          }
        ],
        "Conditions": [
          {
            "Field": "path-pattern",
            "PathPatternConfig": {
              "Values": [
                "/*"
              ]
            }
          }
        ],
        "ListenerArn": {
          "Ref": "ApplicationLoadBalancerHttpListener<TOKEN>"
        },
        "Priority": 100
      },
      "Type": "AWS::ElasticLoadBalancingV2::ListenerRule"
    },
    "ApplicationLoadBalancerHttpListenerGrafanaRuleRule<TOKEN>": {
      "Properties": {
        "Actions": [
          {
            "TargetGroupArn": {
              "Ref": "GrafanaTargetGroup<TOKEN>"
            },
            "Type": "forward"
          }
        ],
        "Conditions": [
          {
            "Field": "path-pattern",
            "PathPatternConfig": {
              "Values": [
                "/grafana/*"
              ]
            }
          }
        ],
        "ListenerArn": {
          "Ref": "ApplicationLoadBalancerHttpListener<TOKEN>"
        },
        "Priority": 20
      },
      "Type": "AWS::ElasticLoadBalancingV2::ListenerRule"
    },
    "BackendTargetGroup<TOKEN>": {
      "Properties": {
        "HealthCheckIntervalSeconds": 30,
        "HealthCheckPath": "/health",
        "HealthCheckPort": "8000",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "Name": "ai-platform-dev-api",
        "Port": 8000,
        "Protocol": "HTTP",
        "TargetGroupAttributes": [
          {
            "Key": "stickiness.enabled",
            "Value": "false"
          }
        ],
        "TargetType": "ip",
        "UnhealthyThresholdCount": 3,
        "VpcId": {
          "Fn::ImportValue": "SnapshotVpc:ExportsOutputRefVpc<TOKEN>"
        }
      },
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup"
    },
    "FrontendTargetGroup<TOKEN>": {
      "Properties": {
        "HealthCheckIntervalSeconds": 30,
        "HealthCheckPath": "/",
        "HealthCheckPort": "3000",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "Name": "ai-platform-dev-frontend",
        "Port": 3000,
        "Protocol": "HTTP",
        "TargetGroupAttributes": [
          {
            "Key": "stickiness.enabled",
            "Value": "false"
          }
        ],
        "TargetType": "ip",
        "UnhealthyThresholdCount": 3,
        "VpcId": {
          "Fn::ImportValue": "SnapshotVpc:ExportsOutputRefVpc<TOKEN>"
        }
      },
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup"
    },
    "GrafanaTargetGroup<TOKEN>": {
      "Properties": {
        "HealthCheckIntervalSeconds": 30,
        "HealthCheckPath": "/api/health",
        "HealthCheckPort": "3000",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "Name": "ai-platform-dev-grafana",
        "Port": 3000,
        "Protocol": "HTTP",
        "TargetGroupAttributes": [
          {
            "Key": "stickiness.enabled",
            "Value": "false"
          }
        ],
        "TargetType": "ip",
        "UnhealthyThresholdCount": 3,
        "VpcId": {
          "Fn::ImportValue": "SnapshotVpc:ExportsOutputRefVpc<TOKEN>"
        }
      },
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup"
    }
  },
  "Rules": {
    "CheckBootstrapVersion": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Contains": [
                  [
                    "1",
                    "2",
                    "3",
                    "4",
                    "5"
                  ],
                  {
                    "Ref": "BootstrapVersion"
                  }
                ]
              }
            ]
          },
          "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI."
        }
      ]
    }
  }
}
