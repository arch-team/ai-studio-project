    "VpcEndpointSg<TOKEN>": {
      "Properties": {
        "GroupDescription": "Security group for VPC endpoints",
        "GroupName": "ai-platform-dev-vpce-sg",
        "SecurityGroupEgress": [
          {
            "CidrIp": "255.255.255.255/32",
            "Description": "Disallow all traffic",
            "FromPort": 252,
            "IpProtocol": "icmp",
            "ToPort": 86
          }
        ],
        "SecurityGroupIngress": [
          {
            "CidrIp": "10.0.64.0/19",
            "Description": "Allow HTTPS from PrivateAppSubnet1",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          },
          {
            "CidrIp": "10.0.96.0/19",
            "Description": "Allow HTTPS from PrivateAppSubnet2",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          },
          {
            "CidrIp": "10.0.128.0/19",
            "Description": "Allow HTTPS from PrivateAppSubnet3",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          },
          {
            "CidrIp": "10.0.160.0/20",
            "Description": "Allow HTTPS from PrivateDataSubnet1",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          },
          {
            "CidrIp": "10.0.176.0/20",
            "Description": "Allow HTTPS from PrivateDataSubnet2",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          },
          {
            "CidrIp": "10.0.192.0/20",
            "Description": "Allow HTTPS from PrivateDataSubnet3",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          },
          {
            "CidrIp": {
              "Fn::GetAtt": [
                "Vpc<TOKEN>",
                "CidrBlock"
              ]
            },
            "Description": {
              "Fn::Join": [
                "",
                [
                  "from ",
                  {
                    "Fn::GetAtt": [
                      "Vpc<TOKEN>",
                      "CidrBlock"
                    ]
                  },
                  ":443"
                ]
              ]
            },
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "ai-platform-dev-vpce-sg"
          }
        ],
        "VpcId": {
          "Ref": "Vpc<TOKEN>"
        }
      },
      "Type": "AWS::EC2::SecurityGroup"
