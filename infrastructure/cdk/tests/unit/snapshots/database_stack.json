{
  "Outputs": {
    "ClusterEndpoint": {
      "Description": "Aurora cluster writer endpoint",
      "Export": {
        "Name": "ai-platform-dev-aurora-endpoint"
      },
      "Value": {
        "Fn::GetAtt": [
          "AuroraCluster<TOKEN>",
          "Endpoint.Address"
        ]
      }
    },
    "Port": {
      "Description": "Aurora cluster port",
      "Export": {
        "Name": "ai-platform-dev-aurora-port"
      },
      "Value": {
        "Fn::GetAtt": [
          "AuroraCluster<TOKEN>",
          "Endpoint.Port"
        ]
      }
    },
    "ProxyEndpoint": {
      "Description": "RDS Proxy endpoint",
      "Export": {
        "Name": "ai-platform-dev-aurora-proxy-endpoint"
      },
      "Value": {
        "Fn::GetAtt": [
          "RdsProxy<TOKEN>",
          "Endpoint"
        ]
      }
    },
    "ReaderEndpoint": {
      "Description": "Aurora cluster reader endpoint",
      "Export": {
        "Name": "ai-platform-dev-aurora-reader-endpoint"
      },
      "Value": {
        "Fn::GetAtt": [
          "AuroraCluster<TOKEN>",
          "ReadEndpoint.Address"
        ]
